export default {
  async fetch(request) {

    // ── 1. Cloudflare 边缘数据（零延迟，最准确）──
    const cf          = request.cf || {};
    const clientIP    = cf.ip || request.headers.get('cf-connecting-ip') || '';
    const isIPv6      = clientIP.includes(':');
    const country     = cf.country          || '';
    const region      = cf.region           || '';
    const city        = cf.city             || '';
    const postalCode  = cf.postalCode       || '';
    const asn         = cf.asn              ? 'AS' + cf.asn : '';
    const asnOrg      = cf.asOrganization   || '';
    const timezone    = cf.timezone         || '';
    const colo        = cf.colo             || '';

    // ── 2. 服务端请求 ip-api.com 补充 ISP / 精确城市 / 时区（无 CORS，无混合内容）──
    let ispName  = asnOrg;
    let cityFull = [region, city].filter(Boolean).join(' · ');
    let tzFull   = timezone;

    try {
      const geoURL = 'http://ip-api.com/json/' + encodeURIComponent(clientIP)
        + '?fields=status,country,regionName,city,isp,org,timezone';
      const geoRes = await fetch(geoURL, {
        headers: { 'User-Agent': 'cf-worker-ip-inspector/2.0' },
        // Worker 侧请求加 3s 超时，避免页面响应变慢
        signal: AbortSignal.timeout(3000),
      });
      if (geoRes.ok) {
        const geo = await geoRes.json();
        if (geo.status === 'success') {
          ispName  = geo.isp  || geo.org  || ispName;
          cityFull = [geo.regionName, geo.city].filter(Boolean).join(' · ') || cityFull;
          tzFull   = geo.timezone || tzFull;
        }
      }
    } catch (_) { /* 用 Cloudflare 自带数据兜底，已在上方赋值 */ }

    // ── 3. XSS 防护：对注入到 HTML 的所有字符串做转义 ──
    const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

    const safeIP      = esc(clientIP   || '未知');
    const safeCountry = esc(country    || '未知');
    const safeCity    = esc(cityFull   || '未知');
    const safeZip     = esc(postalCode || '未知');
    const safeAsn     = esc(asn        || '未知');
    const safeIsp     = esc(ispName    || '未知');
    const safeTz      = esc(tzFull     || '未知');
    const safeColo    = esc(colo);

    const ipTagClass  = isIPv6 ? 'tag-v6' : 'tag-v4';
    const ipTagLabel  = isIPv6 ? 'IPv6' : 'IPv4';
    const dotV6Class  = isIPv6 ? 'dot-on' : 'dot-off';
    const v6PubText   = isIPv6 ? '是（当前连接为 IPv6）' : '否（当前连接为 IPv4）';
    const v6PrioText  = isIPv6 ? '是（IPv6 优先）' : '否（IPv4 优先）';

    const html = `<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>IP 检测</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:       #f7f7f6;
      --white:    #ffffff;
      --surf:     #ffffff;
      --surf2:    #f3f4f6;
      --bdr:      #e5e7eb;
      --bdr2:     #d1d5db;
      --text:     #111827;
      --sub:      #374151;
      --muted:    #9ca3af;
      --blue:     #2563eb;
      --blue-bg:  #eff6ff;
      --blue-bdr: #bfdbfe;
      --green:    #16a34a;
      --green-bg: #f0fdf4;
      --green-bdr:#bbf7d0;
      --amber:    #d97706;
      --amber-bg: #fffbeb;
      --amber-bdr:#fde68a;
      --gray:     #6b7280;
      --gray-bg:  #f9fafb;
      --mono:     'IBM Plex Mono', monospace;
      --sans:     'Inter', system-ui, sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { background: var(--bg); }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 40px 20px 72px;
      font-size: 14px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .wrap { max-width: 560px; margin: 0 auto; }

    /* ── 顶栏 ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 36px;
    }
    .logo { display: flex; align-items: center; gap: 8px; }
    .live-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--green);
      animation: pulse 2.5s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
    .logo-label {
      font-size: 12px; font-weight: 500;
      color: var(--muted); letter-spacing: .08em; text-transform: uppercase;
