    }
    .tag {
      display: inline-flex; align-items: center;
      font-size: 11px; font-weight: 500;
      padding: 3px 9px; border-radius: 20px;
      letter-spacing: .04em;
    }
    .tag-v4 { background: var(--blue-bg); color: var(--blue); border: 1px solid var(--blue-bdr); }
    .tag-v6 { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-bdr); }

    /* ── 分区 ── */
    .sec { margin-bottom: 24px; }
    .sec-title {
      font-size: 11px; font-weight: 500; color: var(--muted);
      letter-spacing: .08em; text-transform: uppercase;
      margin-bottom: 8px; padding-left: 1px;
    }

    /* ── 信息卡 ── */
    .card {
      background: var(--surf);
      border: 1px solid var(--bdr);
      border-radius: 10px;
      overflow: hidden;
    }
    .row {
      display: flex; align-items: flex-start;
      padding: 10px 16px; gap: 12px;
      border-bottom: 1px solid var(--bdr);
      transition: background .12s;
    }
    .row:last-child { border-bottom: none; }
    .row:hover { background: var(--gray-bg); }
    .rk {
      font-size: 13px; color: var(--muted);
      flex: 0 0 128px; padding-top: 1px;
    }
    .rv {
      font-size: 13px; color: var(--text);
      font-family: var(--mono);
      flex: 1; word-break: break-all;
      display: flex; align-items: center; gap: 7px; flex-wrap: wrap;
    }
    .rv.sans { font-family: var(--sans); }

    /* ── 状态点 ── */
    .dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .dot-on  { background: var(--green); }
    .dot-off { background: var(--amber); }
    .dot-unk { background: var(--muted); }
    .dot-spin {
      background: var(--muted);
      animation: spin 1.1s ease-in-out infinite;
    }
    @keyframes spin { 0%,100%{opacity:1} 50%{opacity:.2} }

    /* 只用于 WebRTC 那几行的加载文字 */
    .sc {
      color: var(--muted); font-family: var(--mono); font-size: 13px;
      animation: spin 1.1s ease-in-out infinite;
    }

    /* ── 底部 ── */
    .footer {
      text-align: center; font-size: 12px;
      color: var(--muted); margin-top: 8px;
    }
    .footer strong { color: var(--sub); font-weight: 500; }

    @media (max-width: 460px) {
      .rk { flex: 0 0 108px; font-size: 12px; }
      .rv { font-size: 12px; }
      .topbar { flex-direction: column; align-items: flex-start; gap: 10px; }
    }
  </style>
</head>
<body>
<div class="wrap">

  <!-- 顶栏 -->
  <div class="topbar">
    <div class="logo">
      <div class="live-dot"></div>
      <span class="logo-label">IP Inspector</span>
    </div>
    ${safeColo ? `<div class="colo-pill">Cloudflare &middot; ${safeColo}</div>` : '<div class="colo-pill">Cloudflare</div>'}
  </div>

  <!-- 连接 IP（服务端注入，即时显示） -->
  <div class="hero">
    <div class="hero-eyebrow">您的连接 IP</div>
    <div class="hero-row">
      <span class="hero-ip">${safeIP}</span>
      <span class="tag ${ipTagClass}">${ipTagLabel}</span>
    </div>
  </div>

  <!-- 网络详情 -->
  <div class="sec">
    <div class="sec-title">网络详情</div>
    <div class="card">
      <div class="row">
        <span class="rk">国家 / 地区</span>
        <span class="rv sans">${safeCountry}</span>
      </div>
      <div class="row">
        <span class="rk">城市</span>
        <span class="rv sans">${safeCity}</span>
      </div>
      <div class="row">
        <span class="rk">邮政编码</span>
        <span class="rv">${safeZip}</span>
      </div>
      <div class="row">
        <span class="rk">ASN</span>
        <span class="rv">${safeAsn}</span>
      </div>
      <div class="row">
        <span class="rk">ISP / 运营商</span>
        <span class="rv sans">${safeIsp}</span>
      </div>
      <div class="row">
        <span class="rk">时区</span>
        <span class="rv">${safeTz}</span>
      </div>
    </div>
  </div>

  <!-- IPv6 支持 -->
  <div class="sec">
    <div class="sec-title">IPv6 支持</div>
    <div class="card">
      <div class="row">
        <span class="rk">公网 IPv6</span>
        <span class="rv">
          <span class="dot ${dotV6Class}"></span>${v6PubText}
        </span>
      </div>
      <div class="row">
        <span class="rk">IPv6 访问优先</span>
        <span class="rv">
          <span class="dot ${dotV6Class}"></span>${v6PrioText}
        </span>
      </div>
      <div class="row">
        <span class="rk">本地 IPv6 支持</span>
        <span class="rv" id="v6-local">
          <span class="dot dot-spin"></span><span class="sc">检测中...</span>
        </span>
      </div>
    </div>
  </div>

  <!-- 局域网（WebRTC，必须客户端执行） -->
  <div class="sec">
    <div class="sec-title">局域网（WebRTC）</div>
    <div class="card">
      <div class="row">
        <span class="rk">局域网 IPv4</span>
        <span class="rv" id="lan-v4"><span class="sc">检测中...</span></span>
      </div>
      <div class="row">
        <span class="rk">局域网 IPv6</span>
        <span class="rv" id="lan-v6"><span class="sc">检测中...</span></span>
      </div>
      <div class="row">
        <span class="rk">链路本地 IPv6</span>
        <span class="rv" id="lan-v6-ll"><span class="sc">检测中...</span></span>
      </div>
    </div>
  </div>

  <div class="footer">Powered by <strong>weizhen</strong></div>

</div>
<script>
(function () {
  'use strict';
  var $ = function (id) { return document.getElementById(id); };

  function setLed(id, state, label) {
    var cls = state === 'on' ? 'dot-on' : state === 'off' ? 'dot-off' : 'dot-unk';
    $(id).innerHTML = '<span class="dot ' + cls + '"></span>' + label;
  }

  function setNone(id, msg) {
    $(id).innerHTML = '<span style="color:var(--muted)">' + (msg || '未检测到') + '</span>';
  }

  function detectLocal() {
    var PC = window.RTCPeerConnection
          || window.mozRTCPeerConnection
          || window.webkitRTCPeerConnection;

    if (!PC) {
      setNone('lan-v4', '浏览器不支持');
      setNone('lan-v6', '浏览器不支持');
      setNone('lan-v6-ll', '浏览器不支持');
      setLed('v6-local', 'unk', '无法检测');
      return;
    }

    var pc, v4 = new Set(), v6 = new Set(), v6ll = new Set();

    try {
      pc = new PC({
        iceServers: [
          { urls: 'stun:stun.l.google.com:19302' },
          { urls: 'stun:stun1.l.google.com:19302' },
          { urls: 'stun:stun.cloudflare.com:3478' }
        ]
      });

      // 两个 DataChannel 触发更多 ICE 候选
      pc.createDataChannel('a');
      pc.createDataChannel('b');

      pc.onicecandidate = function (e) {
        if (!e || !e.candidate) {
          // 收集结束
          if (!v4.size)   setNone('lan-v4');
          if (!v6.size)   setNone('lan-v6');
          if (!v6ll.size) setNone('lan-v6-ll');
          if (!v6.size && !v6ll.size) setLed('v6-local', 'off', '不支持');
          closePc();
          return;
        }

        var cand = e.candidate.candidate || '';
        var parts = cand.split(' ');

        // 只取 host 类型（本机直接地址）
        if (parts[7] !== 'host') return;

        var ip = parts[4];
        if (!ip) return;

        // 过滤 Chrome 隐私模式下的 mDNS UUID
        if (/[0-9a-f]{8}-[0-9a-f]{4}-/i.test(ip)) return;
        // 过滤 IPv4-mapped（::ffff:x.x.x.x）
        if (ip.toLowerCase().indexOf('::ffff:') === 0) return;
        // 过滤回环
        if (ip === '127.0.0.1' || ip === '::1') return;

        if (ip.indexOf(':') !== -1) {
          // IPv6
          if (ip.toLowerCase().indexOf('fe80') === 0) {
            // 链路本地
            if (!v6ll.has(ip)) {
              v6ll.add(ip);
              $('lan-v6-ll').textContent = Array.from(v6ll).join('  /  ');
              setLed('v6-local', 'on', '支持');
            }
          } else {
            // 全局 / ULA
            if (!v6.has(ip)) {
              v6.add(ip);
              $('lan-v6').textContent = Array.from(v6).join('  /  ');
              setLed('v6-local', 'on', '支持');
            }
          }
        } else if (/^\d{1,3}(\.\d{1,3}){3}$/.test(ip)) {
          // IPv4
          if (!v4.has(ip)) {
            v4.add(ip);
            $('lan-v4').textContent = Array.from(v4).join('  /  ');
          }
        }
      };

      pc.createOffer()
        .then(function (offer) { return pc.setLocalDescription(offer); })
        .catch(function () {
          setNone('lan-v4', '检测失败');
          setNone('lan-v6', '检测失败');
          setNone('lan-v6-ll', '检测失败');
          setLed('v6-local', 'unk', '检测失败');
        });

    } catch (err) {
      setNone('lan-v4', '检测失败');
      setNone('lan-v6', '检测失败');
      setNone('lan-v6-ll', '检测失败');
      setLed('v6-local', 'unk', '检测失败');
    }

    function closePc() { try { if (pc) pc.close(); } catch (x) {} }

    // 12s 强制收尾，防止页面一直转
    setTimeout(function () {
      closePc();
      ['lan-v4', 'lan-v6', 'lan-v6-ll'].forEach(function (id) {
        if ($(id) && $(id).querySelector('.sc')) setNone(id, '超时');
      });
      var vl = $('v6-local');
      if (vl && vl.querySelector('.sc')) setLed('v6-local', 'unk', '超时');
    }, 12000);
  }

  detectLocal();
}());
</script>
</body>
</html>`;

    return new Response(html, {
      headers: {
        'Content-Type': 'text/html; charset=utf-8',
        'Cache-Control': 'no-store, no-cache',
        'X-Content-Type-Options': 'nosniff',
      },
    });
  },
};
